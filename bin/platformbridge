#!/usr/bin/env php
<?php

/**
 * PlatformBridge CLI
 *
 * Instalace a aktualizace assetů a konfigurace.
 *
 * Usage:
 *   php vendor/bin/platformbridge install        - Kompletní instalace (assety + API + config)
 *   php vendor/bin/platformbridge update         - Aktualizace assetů a API endpointu
 *   php vendor/bin/platformbridge full-install   - npm install + npm build + instalace
 *   php vendor/bin/platformbridge build          - Pouze npm install + npm build
 *
 * @see \Zoom\PlatformBridge\Installer\Installer
 */

// Detekce autoloaderu - podporuje vendor i standalone režim
$autoloaderFound = false;
$autoloadPaths = [
    __DIR__ . '/../../../autoload.php',          // vendor/zoom/platform-bridge/bin → vendor/autoload.php
    __DIR__ . '/../vendor/autoload.php',         // standalone: bin → vendor/autoload.php
];

foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require_once $autoloadPath;
        $autoloaderFound = true;
        break;
    }
}

if (!$autoloaderFound) {
    fwrite(STDERR, "Error: Could not find autoload.php. Run 'composer install' first.\n");
    exit(1);
}

use Zoom\PlatformBridge\Installer\Installer;

$command = $argv[1] ?? 'install';
$installer = new Installer();

switch ($command) {
    case 'install':
        $installer->install();
        break;

    case 'update':
        $installer->update();
        break;

    case 'full-install':
        $installer->fullInstall();
        break;

    case 'build':
        $buildScript = $argv[2] ?? 'build';
        $success = $installer->buildAssets($buildScript);
        if (!$success) {
            exit(1);
        }
        break;

    default:
        fwrite(STDERR, "Unknown command: {$command}\n");
        fwrite(STDERR, "Usage: platformbridge [install|update|full-install|build]\n");
        fwrite(STDERR, "\n");
        fwrite(STDERR, "Commands:\n");
        fwrite(STDERR, "  install        Publish assets, API endpoint and config\n");
        fwrite(STDERR, "  update         Update assets and API endpoint (keeps config)\n");
        fwrite(STDERR, "  full-install   npm install + npm build + install\n");
        fwrite(STDERR, "  build [script] Run npm install + npm build (default: 'build')\n");
        exit(1);
}