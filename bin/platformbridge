#!/usr/bin/env php
chmod +x bin/platformbridge
<?php

/**
 * PlatformBridge CLI
 *
 * Instalace a aktualizace assetů a konfigurace.
 *
 * Usage:
 *   php vendor/bin/platformbridge install          - Kompletní instalace (assety + API + config + JSON)
 *   php vendor/bin/platformbridge update           - Aktualizace assetů a API endpointu
 *   php vendor/bin/platformbridge publish:config   - Publikuje POUZE konfiguraci (bridge-config.php)
 *   php vendor/bin/platformbridge publish:json     - Publikuje POUZE JSON soubory
 *
 * @see \Zoom\PlatformBridge\Installer\Installer
 */

// Detekce autoloaderu - podporuje vendor i standalone režim
$autoloaderFound = false;
$autoloadPaths = [
    __DIR__ . '/../../../autoload.php',          // vendor/zoom/platform-bridge/bin → vendor/autoload.php
    __DIR__ . '/../vendor/autoload.php',         // standalone: bin → vendor/autoload.php
];

foreach ($autoloadPaths as $autoloadPath) {
    if (file_exists($autoloadPath)) {
        require_once $autoloadPath;
        $autoloaderFound = true;
        break;
    }
}

if (!$autoloaderFound) {
    fwrite(STDERR, "Error: Could not find autoload.php. Run 'composer install' first.\n");
    exit(1);
}

use Zoom\PlatformBridge\Installer\Installer;

$command = $argv[1] ?? 'install';
$installer = new Installer();

switch ($command) {
    case 'install':
        $installer->install();
        break;

    case 'update':
        $installer->update();
        break;

    case 'publish:config':
        $installer->publishConfig();
        break;

    case 'publish:json':
        $installer->publishJson();
        break;

    default:
        fwrite(STDERR, "Unknown command: {$command}\n");
        fwrite(STDERR, "Usage: platformbridge [install|update|publish:config|publish:json]\n");
        fwrite(STDERR, "\n");
        fwrite(STDERR, "Commands:\n");
        fwrite(STDERR, "  install          Publish assets, API endpoint, config and JSON files\n");
        fwrite(STDERR, "  update           Update assets and API endpoint (keeps config)\n");
        fwrite(STDERR, "  publish:config   Publish ONLY bridge-config.php (skip if exists)\n");
        fwrite(STDERR, "  publish:json     Publish ONLY JSON config files (skip if exists)\n");
        exit(1);
}