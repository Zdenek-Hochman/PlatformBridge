#!/usr/bin/env php
<?php

/**
 * PlatformBridge CLI – Installer & Updater
 *
 * Tento soubor se spouští výhradně jako vendor binary přes Composer:
 *   vendor/platformbridge/platform-bridge/bin/platformbridge
 *
 * Cesta k autoloaderu je proto vždy vendor/autoload.php (3× dirname z bin/).
 */

// ─── Autoloader ──────────────────────────────────────────────

$autoloadPath = dirname(__DIR__, 3) . '/autoload.php';

if (!file_exists($autoloadPath)) {
    fwrite(STDERR, <<<'ERR'

  [ERROR] Nebyl nalezen vendor/autoload.php.

  Tento skript lze spouštět pouze jako Composer vendor binary.
  Ujistěte se, že jste spustili `composer install` v hostitelském projektu.

ERR);
    exit(1);
}

require_once $autoloadPath;

use PlatformBridge\Installer\Installer;

// ─── Parsování CLI ───────────────────────────────────────────

$command  = $argv[1] ?? null;
$cliArgs  = array_slice($argv, 2);

if ($command === null || $command === '--help' || $command === '-h') {
    printUsage();
    exit(0);
}

// ─── Spuštění příkazu ────────────────────────────────────────

$installer = new Installer();
$installer->applyCliOptions($cliArgs);

switch ($command) {
    case 'init':
        $installer->init();
        break;

    case 'install':
        $installer->install();
        break;

    case 'update':
        $installer->update();
        break;

    default:
        fwrite(STDERR, "  [ERROR] Neznámý příkaz: {$command}\n\n");
        printUsage();
        exit(1);
}

// ─── Help ────────────────────────────────────────────────────

function printUsage(): void
{
    $usage = <<<'USAGE'
PlatformBridge CLI v1.0
=======================

Instalační a aktualizační nástroj pro PlatformBridge.
Spouští se výhradně jako Composer vendor binary.

Použití:
  platformbridge <příkaz> [volby]

Příkazy:
  init      Inicializace konfiguračního souboru platformbridge.json.php
            (migrace / publish / přeskočení dle aktuálního stavu)
  install   Kompletní instalace – init, adresáře, guardy, assety,
            API endpoint, bridge-config, security-config, cache
  update    Aktualizace assetů a API endpointu (konfigurace zůstane)

Volby:
  --force          Přepsat i existující konfigurační soubory
                   (výchozí: přeskočit pokud existují)
  --only=<kroky>   Spustit jen vybrané kroky (čárkou oddělené):
                     init, dirs, guard, assets, api, config, security, cache
  --help, -h       Zobrazit tuto nápovědu

Příklady:
  platformbridge install                         Kompletní instalace
  platformbridge install --force                 Instalace s přepsáním konfigurací
  platformbridge install --only=assets           Pouze publikace JS/CSS assetů
  platformbridge install --only=config,security  Pouze konfigurační soubory
  platformbridge init                            Pouze inicializace konfigurace
  platformbridge update                          Aktualizace assetů + API

Kroky (install):
  init → dirs → guard → assets → api → config → security → cache

Poznámka:
  Ve standalone/dev režimu není installer potřeba – soubory se čtou
  přímo ze zdrojových složek. Installer je určen pro vendor režim
  (instalace přes Composer do hostitelské aplikace).
USAGE;

    echo $usage . PHP_EOL;
}