<div class="ai-result__actions" data-component="ai-handlers">
	<button data-action="repeat" role="{$key} {$counter} repeat" class="ai-result__action">
		<svg class="ai-result__icon"><use href="#ai-repeat"></use></svg>
	</button>

	<button data-action="copy" role="{$key} {$counter} copy" class="ai-result__action">
		<svg class="ai-result__icon"><use href="#ai-copy"></use></svg>
	</button>

	<button data-action="thumb-up" role="{$key} {$counter} thumb-up" class="ai-result__action">
		<svg class="ai-result__icon"><use href="#ai-thumb-up"></use></svg>
	</button>

	<button data-action="thumb-down" role="{$key} {$counter} thumb-down" class="ai-result__action">
		<svg class="ai-result__icon"><use href="#ai-thumb-down"></use></svg>
	</button>

	<div data-action="use" role="{$key} {$counter} use" class="ai-result__use">POUŽÍT</div>
</div>