<div class="pb-result__actions" data-component="pb-handlers">
	<button data-action="repeat" role="{$key} {$counter} repeat" class="pb-result__action">
		<svg class="pb-result__icon"><use href="#pb-repeat"></use></svg>
	</button>

	<button data-action="copy" role="{$key} {$counter} copy" class="pb-result__action">
		<svg class="pb-result__icon"><use href="#pb-copy"></use></svg>
	</button>

	<button data-action="thumb-up" role="{$key} {$counter} thumb-up" class="pb-result__action">
		<svg class="pb-result__icon"><use href="#pb-thumb-up"></use></svg>
	</button>

	<button data-action="thumb-down" role="{$key} {$counter} thumb-down" class="pb-result__action">
		<svg class="pb-result__icon"><use href="#pb-thumb-down"></use></svg>
	</button>

	<div data-action="use" role="{$key} {$counter} use" class="pb-result__use">POUŽÍT</div>
</div>