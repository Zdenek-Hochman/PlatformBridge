	{
		"blocks": {
			"language": {
				"id": "language",
				"name": "lang",
				"ai_key": "Language",
				"component": "input",
				"variant": "radio",
				"label": "{$config.language.label|Text language variant}",
				"rules": {
					"default": "en"
				},
				"group": [
					{ "value": "cs", "label": "CZ" },
					{ "value": "en", "label": "EN" },
					{ "value": "de", "label": "DE" },
					{ "value": "fr", "label": "FR" },
					{ "value": "it", "label": "IT" },
					{ "value": "es", "label": "ES" }
				]
			},
			"tone": {
				"id": "tone",
				"name": "tone",
				"ai_key": "CommunicationTone",
				"component": "select",
				"label": "{$config.tone.label|Tone}",
				"rules": {
					"default": "formal",
					"required": true
				},
				"options": [
					{ "value": "friendly", "label": "{$config.tone.options.friendly|Friendly}" },
					{ "value": "formal", "label": "{$config.tone.options.formal|Formal}" },
					{ "value": "informative", "label": "{$config.tone.options.informative|Informative}" }
				]
			},
			"goal": {
				"id": "goal",
				"name": "goal",
				"ai_key": "MessagePurpose",
				"component": "select",
				"label": "{$config.goal.label|Goal}",
				"tooltip": "{$config.goal.tooltip|Select the main purpose of the message}",
				"rules": {
					"default": "survey",
					"disabled": false
				},
				"options": [
					{ "value": "survey", "label": "{$config.goal.options.survey|Survey}" },
					{ "value": "reminder", "label": "{$config.goal.options.reminder|Reminder}" },
					{ "value": "announcement", "label": "{$config.goal.options.announcement|Announcement / News}" }
				]
			},
			"campaign_type": {
				"id": "campaign_type",
				"name": "campaign_type",
				"ai_key": "CampaignType",
				"component": "select",
				"label": "{$config.campaign_type.label|Campaign type}",
				"tooltip": "{$config.campaign_type.tooltip|Select the campaign type}",
				"rules": {
					"default": "offer"
				},
				"options": [
					{ "value": "offer", "label": "{$config.campaign_type.options.offer|Offer}" },
					{ "value": "transactional", "label": "{$config.campaign_type.options.transactional|Transactional}" },
					{ "value": "newsletter", "label": "{$config.campaign_type.options.newsletter|Newsletter}" },
					{ "value": "survey", "label": "{$config.campaign_type.options.survey|Survey}" },
					{ "value": "promo", "label": "{$config.campaign_type.options.promo|Promo}" }
				]
			},
			"emoji": {
				"id": "emoji",
				"name": "emoji_enabled",
				"ai_key": "EmojiInSubject",
				"component": "input",
				"variant": "checkbox",
				"label": "{$config.emoji.label|Emoji in subject}",
				"value": "OK",
				"rules": {
					"checked": false
				},
				"meta": {
					"info": "{$config.emoji.meta.info|Select the language in which you want to generate the text.}"
				}
			},
			"personalization": {
				"id": "personalization",
				"name": "personalization",
				"ai_key": "UsePersonalization",
				"component": "input",
				"variant": "checkbox",
				"label": "{$config.personalization.label|Personalization}",
				"rules": {
					"checked": true
				}
			},
			"topic_source": {
				"id": "topic_source",
				"name": "topic_source",
				"ai_key": "SubjectSource",
				"component": "input",
				"variant": "radio",
				"rules": {
					"default": "custom",
					"required": true
				},
				"group": [
					{ "value": "template", "label": "{$config.topic_source.options.template|From template content}" },
					{ "value": "custom", "label": "{$config.topic_source.options.custom|From custom text}" }
				]
			},
			"template_id": {
				"id": "template_id",
				"name": "template_id",
				"ai_key": "TemplateID",
				"component": "input",
				"variant": "hidden",
				"rules": {}
			},
			"email_topic": {
				"id": "email_topic",
				"name": "email_topic",
				"ai_key": "SubjectText",
				"component": "input",
				"variant": "text",
				"small": "{$config.email_topic.small|Recommended length: min 30 characters}",
				"value": "announcement",
				"rules": {
					"placeholder": "{$config.email_topic.placeholder|E.g. Invitation to Christmas cookie tasting}",
					"autocomplete": "off",
					"readonly": false,
					"disabled": false,
					"minlength": 30,
					"required": true,
					"visible_if": {
						"topic_source": "custom"
					}
				},
				"meta": {
					"test": "{$config.email_topic.meta.test|OK}"
				}
			}
		}
	}