{
    "name": "zoom/platform-bridge",
    "description": "AI-powered form builder with template engine and field factory",
    "type": "library",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
    		"Zoom\\PlatformBridge\\": "src/PlatformBridge/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "post-install-cmd": [
			"@php bin/platformbridge install"
        ],
        "post-update-cmd": [
            "@php bin/platformbridge update"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        }
    },
	"authors": [
        {
            "name": "Zdeněk Hochman",
            "email": "zdenek.hochman@virtualzoom.com"
        }
	],
	"bin": [
    	"bin/platformbridge"
  	]
}